@inherits LayoutComponentBase

<div class="app-page">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <div class="app-shell">
        <header class="app-header">
            <div class="header-context">
                <span class="header-eyebrow">
                    Calisto Interactive
                </span>

                <span class="header-title">
                    GameHub
                </span>
            </div>

            <div class="header-actions">
                <span class="environment-badge">
                    <span class="environment-indicator"
                          aria-hidden="true"></span>

                    Frontend Preview
                </span>
            </div>
        </header>

        <main class="app-main">
            <article class="content">
                @Body
            </article>
        </main>

        <footer class="app-footer">
            <span>
                © @DateTime.UtcNow.Year Calisto Interactive
            </span>

            <span>
                GameHub Platform
            </span>
        </footer>
    </div>
</div>

<div id="blazor-error-ui">
    <span>An unexpected error has occurred.</span>
    <a href="" class="reload">Reload</a>
    <button type="button"
            class="dismiss"
            aria-label="Dismiss error">
        ×
    </button>
</div>