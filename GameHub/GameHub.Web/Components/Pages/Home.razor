@page "/"

<PageTitle>GameHub | Calisto Interactive</PageTitle>

<section class="hero">
    <div class="hero-content">
        <span class="eyebrow">
            Calisto Interactive presents
        </span>

        <h1>
            One platform.<br />
            <span>Every game journey.</span>
        </h1>

        <p class="hero-description">
            GameHub connects players, game progress, achievements,
            purchases and future Calisto Interactive worlds through
            one secure and evolving platform.
        </p>

        <div class="hero-actions">
            <a class="btn btn-primary hero-primary-action"
               href="#platform">
                Explore the platform
            </a>

            <a class="secondary-action"
               href="system-status">
                View system status
                <span aria-hidden="true">→</span>
            </a>
        </div>

        <div class="foundation-status">
            <span class="status-light" aria-hidden="true"></span>

            <span>
                <strong>Backend foundation operational</strong>
                <small>Blazor frontend currently in development</small>
            </span>
        </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
        <div class="visual-glow"></div>
        <div class="orbit orbit-outer"></div>
        <div class="orbit orbit-middle"></div>
        <div class="orbit orbit-inner"></div>

        <div class="brand-core">
            <img src="images/brand/calisto-interactive-logo.png?v=2"
                 alt="" />
        </div>

        <span class="orbit-point point-one"></span>
        <span class="orbit-point point-two"></span>
        <span class="orbit-point point-three"></span>
    </div>
</section>

<section id="platform" class="platform-section">
    <div class="section-heading">
        <div>
            <span class="eyebrow">The GameHub ecosystem</span>
            <h2>Built to connect every part of the experience.</h2>
        </div>

        <p>
            A scalable foundation created for players, games and the
            future digital services of Calisto Interactive.
        </p>
    </div>

    <div class="feature-grid">
        <article class="feature-card">
            <div class="feature-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="12" cy="8" r="4"></circle>
                    <path d="M4.5 21a7.5 7.5 0 0 1 15 0"></path>
                </svg>
            </div>

            <span class="feature-number">01</span>
            <h3>Player Identity</h3>

            <p>
                Secure accounts and player profiles designed to follow
                users throughout the Calisto ecosystem.
            </p>
        </article>

        <article class="feature-card">
            <div class="feature-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M5 4h14v16H5z"></path>
                    <path d="M8 4v5h8V4"></path>
                    <path d="M8 16h8"></path>
                </svg>
            </div>

            <span class="feature-number">02</span>
            <h3>Persistent Progress</h3>

            <p>
                Save games, achievements and progression connected to
                each player and ready for future game worlds.
            </p>
        </article>

        <article class="feature-card">
            <div class="feature-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M4 18 9 5l3 8 3-5 5 10"></path>
                    <path d="M3 21h18"></path>
                </svg>
            </div>

            <span class="feature-number">03</span>
            <h3>Competitive Worlds</h3>

            <p>
                Leaderboards and achievement systems built to support
                competition, recognition and player history.
            </p>
        </article>

        <article class="feature-card">
            <div class="feature-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M3 6h18l-2 11H5L3 6Z"></path>
                    <path d="M8 6a4 4 0 0 1 8 0"></path>
                    <circle cx="8" cy="20" r="1"></circle>
                    <circle cx="17" cy="20" r="1"></circle>
                </svg>
            </div>

            <span class="feature-number">04</span>
            <h3>Connected Commerce</h3>

            <p>
                A commercial foundation for games, additional content,
                purchases and secure payment evolution.
            </p>
        </article>
    </div>
</section>

<section class="wild-hunter-section">
    <div class="wild-hunter-visual">
        <span class="game-label">First Calisto title</span>

        <div class="game-monogram" aria-hidden="true">
            WH
        </div>
    </div>

    <div class="wild-hunter-content">
        <span class="eyebrow">The first world is coming</span>
        <h2>Wild Hunter</h2>

        <p>
            Wild Hunter will become the first game developed from its
            foundations alongside GameHub, connecting the journey from
            development to publication inside the Calisto ecosystem.
        </p>

        <div class="coming-soon">
            <span class="status-light" aria-hidden="true"></span>
            Identity and game experience in development
        </div>
    </div>
</section>