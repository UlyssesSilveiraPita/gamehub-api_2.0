@page "/access-denied"

<PageTitle>Access Denied | GameHub</PageTitle>

<section class="access-denied-page">
    <div class="access-denied-card">
        <span class="access-denied-code">
            403
        </span>

        <span class="access-denied-eyebrow">
            Authorization required
        </span>

        <h1>Access denied</h1>

        <p>
            Your GameHub account does not have permission
            to access this area.
        </p>

        <div class="access-denied-actions">
            <a class="btn btn-primary" href="/">
                Return to Home
            </a>
        </div>
    </div>
</section>